# === BLOCK QUIC FOR YOUTUBE MITM ===

# === BLOCK iOS OTA UPDATES ===
host, mesu.apple.com, reject
host, gdmf.apple.com, reject
host, updates-http.apple.com, reject

# === BLOCK WEBRTC LEAK (Specific servers) ===
# Note: Generic KEYWORD stun/turn removed — breaks VoIP (FaceTime, WhatsApp, Zoom)
host-suffix, stun.l.google.com, reject
host-suffix, stun1.l.google.com, reject
host-suffix, stun2.l.google.com, reject
host-suffix, stun3.l.google.com, reject
host-suffix, stun4.l.google.com, reject

# === SPOTIFY ADS ===
