      match: ^https?:\/\/user-kaji-api\.b612kaji\.com\/v\d\/purchase\/subscription\/subscriber\/status
      script-provider: b612-res
      require-body: true
      timeout: 60
  - http-response:
      name: meitu-res
      match: ^https?:\/\/(h5|api)\.xiuxiu\.meitu\.com\/v\d\/(h\d\/vip|vip|user)\/
      script-provider: meitu-res
      require-body: true
      timeout: 60
  - http-response:
      name: fun-res
      match: ^https:\/\/api\.funimate\.com\/users\/me
      script-provider: fun-res
      require-body: true
      timeout: 10
  - http-response:
      name: itunes-res
      match: ^https?:\/\/buy\.itunes\.apple\.com\/verifyReceipt$
      script-provider: itunes-res
      require-body: true
      timeout: 60
  - http-response:
      name: wps-res
      match: ^https?:\/\/.*?account\.wps\.(com|cn)(:\d+)?\/api\/users\/\w+\/overview$
      script-provider: wps-res
      require-body: true
      timeout: 10
  - http-response:
      name: xmind-res
      match: ^https?:\/\/www\.xmind\.(cn|net|app)\/_res\/devices
      script-provider: xmind-res
      require-body: true
      timeout: 10
  - http-response:
      name: alarmy-res
      match: ^https:\/\/ars\.alar\.my\/api\/v2\/user\/sync
      script-provider: alarmy-res
      require-body: true
      timeout: 10
  - http-response:
      name: grammarly-res
      match: ^https?:\/\/subscription\.grammarly\.com\/api\/v1\/subscription$
      script-provider: grammarly-res
      require-body: true
      timeout: 10
  - http-response:
      name: notability-res
      match: ^https:\/\/notability\.com\/subscriptions
      script-provider: notability-res
      require-body: true
      timeout: 10
  - http-response:
      name: photomath-res
      match: ^https?:\/\/lapi\.photomath\.net\/v4\/me
      script-provider: photomath-res
      require-body: true
      timeout: 10
  - http-response:
      name: smallpdf-res
      match: ^https?:\/\/pro\.smallpdf\.com\/pro\/account
      script-provider: smallpdf-res
      require-body: true
      timeout: 10
  - http-response:
      name: peak-res
      match: ^https:\/\/billing\.peakcloud\.org\/billing\/2\/user\/me
      script-provider: peak-res
