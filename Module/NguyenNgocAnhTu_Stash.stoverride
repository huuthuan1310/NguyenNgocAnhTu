scriptings:
  - http-request:
      name: yt-req
      match: ^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|reel\/reel_watch_sequence|get_watch)
      script-provider: yt-req
      require-body: true
      binary-mode: true
      timeout: 10
  - http-response:
      name: yt-res
      match: ^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch)
      script-provider: yt-res
      require-body: true
      binary-mode: true
      timeout: 30
      argument: '{"lyricLang":"vi","captionLang":"vi","blockUpload":false,"blockImmersive":false,"debug":false}'
  - http-request:
      name: sp-json
      match: ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/
      script-provider: sp-json
      timeout: 10
  - http-response:
      name: sp-proto
      match: ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$
      script-provider: sp-proto
      require-body: true
      binary-mode: true
      timeout: 10
  - http-response:
      name: rc-res
      match: ^https:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^/]+$)
      script-provider: rc-res
      require-body: true
      timeout: 60
  - http-response:
      name: rc-backup
      match: ^https:\/\/api\.rc-backup\.com\/.+\/(receipts$|subscribers\/[^/]+$)
      script-provider: rc-backup
      require-body: true
      timeout: 60
  - http-response:
      name: sc-res
      match: ^https?:\/\/api-mobile\.soundcloud\.com\/configuration\/ios
      script-provider: sc-res
      require-body: true
      timeout: 15
  - http-response:
      name: pa-res
      match: ^https:\/\/api\.picsart\.com\/gw-v2\/shop\/subscription\/apple\/purchases
      script-provider: pa-res
      require-body: true
      timeout: 60
  - http-response:
      name: pa-storages
      match: ^https:\/\/api\.picsart\.com\/gw-v2\/cloud-storage\/v1\/me\/storages
      script-provider: pa-storages
      require-body: true
      timeout: 60
  - http-response:
      name: pa-nobyda
      match: ^https?:\/\/api\.(picsart|meiease)\.c(n|om)\/users\/show\/me\.json
      script-provider: pa-nobyda
      require-body: true
      timeout: 60
  - http-response:
      name: lr-res
      match: ^https:\/\/photos\.adobe\.io\/v2\/accounts
      script-provider: lr-res
      require-body: true
      timeout: 10
  - http-response:
      name: ps-res
      match: ^https:\/\/lcs-mobile-cops\.adobe\.io\/mobile_profile
      script-provider: ps-res
      require-body: true
      timeout: 10
  - http-response:
      name: emby-res
      match: ^https?:\/\/mb3admin\.com\/admin\/service\/registration\/validateDevice
      script-provider: emby-res
      require-body: true
      timeout: 10
  - http-response:
      name: km-res
      match: ^https:\/\/api-account\.kinemasters\.com\/v\d\/user\/subscribe$
      script-provider: km-res
      require-body: true
      timeout: 10
  - http-response:
      name: dj-res
      match: ^https:\/\/app\.algoriddim\.com\/api\/v1\/validate-receipt
      script-provider: dj-res
      require-body: true
      timeout: 10
  - http-response:
      name: calm-res
      match: ^https?:\/\/api\.calm\.com\/(me|device|ios\/receipt)
      script-provider: calm-res
      require-body: true
      timeout: 10
  - http-response:
      name: busuu-res
      match: ^https:\/\/api\.busuu\.com\/users\/me
      script-provider: busuu-res
      require-body: true
      timeout: 10
  - http-response:
      name: hs-res
      match: ^https:\/\/api\.prod\.headspace\.com\/.*\/user-subscriptions
      script-provider: hs-res
      require-body: true
      timeout: 10
  - http-response:
      name: am-res
      match: ^https:\/\/us-central1-alight-creative\.cloudfunctions\.net\/getAccountStatusAndLicenses
      script-provider: am-res
      require-body: true
      timeout: 10
  - http-response:
      name: wink-res
      match: ^https?:\/\/api-sub\.meitu\.com\/v2\/user\/vip_info_by_group\.json
      script-provider: wink-res
      require-body: true
      timeout: 10
  - http-response:
      name: tc-res
      match: ^https:\/\/premium-(.+)\.truecaller\.com\/v\d\/(subscriptions|products\/apple)
      script-provider: tc-res
      require-body: true
      timeout: 10
  - http-response:
      name: cs-res
      match: ^https:\/\/(api|api-cs.*)\.intsig\.net\/(purchase\/cs\/query_prop|queryProperty|getPrivilegeItem)
      script-provider: cs-res
      require-body: true
      timeout: 15
  - http-response:
