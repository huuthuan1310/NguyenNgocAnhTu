name: ⚡ Anh Tú Premium - Stash
desc: 67 Apps - Locket Gold + YouTube + Spotify + SoundCloud + PicsArt + Lightroom + Photoshop + Emby + KineMaster + Djay + Calm + Busuu + Headspace + AlightMotion + Wink + Truecaller + CamScanner + BeautyPlus + VSCO + Snow + B612 + Meitu + Funimate + iTunes + WPS + Xmind + Alarmy + Grammarly + Notability + Photomath + Smallpdf + Peak + Polarr + MyFitnessPal + Musixmatch + Fimo + Varlens + Darkroom + OldRoll + PhotoRoom + Pixelcut + Mojo + Boom + Audiomack + Fantastical + Craft + DayOne + Nicegram + iLovePDF + Mondly + Memrise + Aloha + DailyYoga + AccuWeather + SparkMail + Endel + Flomo + Drafts + Keep + ColorWidgets + WidgetSmith + InVideo + Pandora + Beelinguapp + Relens + TouchRetouch + Emote + Sub-Store | v1.2.0 (2026-05-24)
author: Nguyễn Ngọc Anh Tú
homepage: https://github.com/ekaznyra/NguyenNgocAnhTu
icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Apple.png

rules:
  - DOMAIN-SUFFIX,audio-ak-spotify-com.akamaized.net,REJECT
  - DOMAIN-SUFFIX,audio4-ak-spotify-com.akamaized.net,REJECT
  - DOMAIN-SUFFIX,heads-ak-spotify-com.akamaized.net,REJECT
  - DOMAIN-SUFFIX,heads4-ak-spotify-com.akamaized.net,REJECT
  - DOMAIN,spclient.wg.spotify.com,DIRECT
  - DOMAIN-KEYWORD,spotify-ads,REJECT
  - AND,((DOMAIN-SUFFIX,googlevideo.com),(PROTOCOL,UDP)),REJECT
  - AND,((DOMAIN,youtubei.googleapis.com),(PROTOCOL,UDP)),REJECT

http:
  mitm:
    - "*.googlevideo.com"
    - "www.youtube.com"
    - "s.youtube.com"
    - "youtubei.googleapis.com"
    - "spclient.wg.spotify.com"
    - "*-spclient.spotify.com"
    - "api.revenuecat.com"
    - "api.rc-backup.com"
    - "buy.itunes.apple.com"
    - "api.picsart.c*"
    - "api.meiease.c*"
    - "api-mobile.soundcloud.com"
    - "api-account.kinemasters.com"
    - "photos.adobe.io"
    - "lcs-mobile-cops.adobe.io"
    - "app.algoriddim.com"
    - "api.calm.com"
    - "api.busuu.com"
    - "vsco.co"
    - "mb3admin.com"
    - "api.prod.headspace.com"
    - "api.funimate.com"
    - "us-central1-alight-creative.cloudfunctions.net"
    - "api-sub.meitu.com"
    - "premium*.truecaller.com"
    - "ap*.intsig.net"
    - "api.mr.pixocial.com"
    - "newbeee-api.beautyplus.com"
    - "user-snow-api.snow.me"
    - "user-kaji-api.b612kaji.com"
    - "h5.xiuxiu.meitu.com"
    - "api.xiuxiu.meitu.com"
    - "account.wps.cn"
    - "*account.wps.com"
    - "www.xmind.cn"
    - "www.xmind.net"
    - "www.xmind.app"
    - "ars.alar.my"
    - "sub.store"
    - "subscription.grammarly.com"
    - "notability.com"
    - "lapi.photomath.net"
    - "pro.smallpdf.com"
    - "billing.peakcloud.org"
    - "api.polaxiong.com"
    - "premium-api.myfitnesspal.com"
    - "apic.musixmatch.com"
    - "server.yoyiapp.com"
    - "mid.zineapi.com"
    - "apimboom2.globaldelight.net"
    - "api.flexibits.com"
    - "api.craft.do"
    - "dayone.app"
    - "restore-access.indream.app"
    - "service.ilovepdf.com"
    - "api.mondlylanguages.com"
    - "api.memrise.com"
    - "api.alohaprofile.com"
    - "pre.dailyyoga.com"
    - "app-subscription-proxy.accuweather.com"
    - "api-production.endel.io"
    - "flomoapp.com"
    - "backend.getdrafts.com"
    - "api.gotokeep.com"
    - "payments.invideo.io"

  url-rewrite:
    - ^https?:\/\/[\w-]+\.googlevideo\.com\/(?!(dclk_video_ads|videoplayback\?)).+&oad - reject-200
    - ^https?:\/\/(www|s)\.youtube\.com\/api\/stats\/ads - reject-200
    - ^https?:\/\/(www|s)\.youtube\.com\/(pagead|ptracking) - reject-200
    - ^https?:\/\/s\.youtube\.com\/api\/stats\/qoe\?adcontext - reject-200

  header-rewrite:
    - ^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) header-del x-revenuecat-etag
    - ^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) header-del X-RevenueCat-ETag
    - ^https?:\/\/api\.rc-backup\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) header-del x-revenuecat-etag
    - ^https?:\/\/api\.rc-backup\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) header-del X-RevenueCat-ETag
    - ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(user-customization-service\/v1\/customize|bootstrap\/v1\/bootstrap)$ header-del if-none-match

  script:
    # 📺 YouTube Premium - ekaznyra
    - match: ^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|reel\/reel_watch_sequence|get_watch)
      name: yt-req
      type: request
      require-body: true
      timeout: 20
      max-size: -1
      binary-mode: true
    - match: ^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch)
      name: yt-res
      type: response
      require-body: true
      timeout: 30
      max-size: -1
      binary-mode: true
      argument: '{"lyricLang":"vi","captionLang":"vi","blockUpload":false,"blockImmersive":false,"debug":false}'
    # 🎵 Spotify Premium
    - match: ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/
      name: sp-json
      type: request
      require-body: false
      timeout: 10
    - match: ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$
      name: sp-proto
      type: response
      require-body: true
      timeout: 10
      max-size: 0
      binary-mode: true
    # 🔐 RevenueCat Multi-App (Locket Gold)
    - match: ^https:\/\/api\.revenuecat\.com\/.*\/(receipts$|subscribers\/[^/]+$)
      name: rc-res
      type: response
      require-body: true
      timeout: 60
      max-size: -1
    - match: ^https:\/\/api\.revenuecat\.com\/.*\/(receipts|subscribers)
      name: rc-hdr
      type: request
      require-body: false
      timeout: 5
    - match: ^https:\/\/api\.rc-backup\.com\/.*\/(receipts$|subscribers\/[^/]+$)
      name: rc-backup
      type: response
      require-body: true
      timeout: 60
      max-size: -1
    # 🎧 SoundCloud Go+ (yfamilys)
    - match: ^https?:\/\/api-mobile\.soundcloud\.com\/configuration\/ios
      name: sc-res
      type: response
      require-body: true
      timeout: 15
      max-size: 262144
    # 🎨 PicsArt Gold
    - match: ^https:\/\/api\.picsart\.com\/gw-v2\/shop\/subscription\/apple\/purchases
      name: pa-res
      type: response
      require-body: true
      timeout: 60
    - match: ^https:\/\/api\.picsart\.com\/gw-v2\/cloud-storage\/v1\/me\/storages
      name: pa-storages
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/api\.(picsart|meiease)\.c(n|om)\/users\/show\/me\.json
      name: pa-nobyda
      type: response
      require-body: true
      timeout: 60
      max-size: 0
    # 🎨 Lightroom (yfamilys)
    - match: ^https:\/\/photos\.adobe\.io\/v2\/accounts
      name: lr-res
      type: response
      require-body: true
      timeout: 10
      max-size: 131072
    # 🎨 Photoshop Express
    - match: ^https:\/\/lcs-mobile-cops\.adobe\.io\/mobile_profile
      name: ps-res
      type: response
      require-body: true
      timeout: 10
      max-size: 131072
    # 🎬 Emby Premiere
    - match: ^https?:\/\/mb3admin\.com\/admin\/service\/registration\/validateDevice
      name: emby-res
      type: response
      require-body: true
      timeout: 10
      max-size: 131072
    # 🎬 KineMaster Pro
    - match: ^https:\/\/api-account\.kinemasters\.com\/v\d\/user\/subscribe$
      name: km-res
      type: response
      require-body: true
      timeout: 10
      max-size: 131072
    # 🎵 Djay Pro
    - match: ^https:\/\/app\.algoriddim\.com\/api\/v1\/validate-receipt
      name: dj-res
      type: response
      require-body: true
      timeout: 10
      max-size: 131072
    # 🧘 Calm (yfamilys)
    - match: ^https?:\/\/api\.calm\.com\/(me|device|ios\/receipt)
      name: calm-res
      type: response
      require-body: true
      timeout: 10
      max-size: 0
    # 📚 Busuu
    - match: ^https:\/\/api\.busuu\.com\/users\/me
